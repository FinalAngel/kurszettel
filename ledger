#!/usr/bin/env bash
# Ledger entrypoint.
#
# Run ANY command in this repo through it and, when the command finishes, the
# repo spends a few minutes (default 5) trying to improve itself in the
# background — back-testing and tuning its own signals, self-healing, and
# (if you opt in) letting an LLM refactor code, all gated by the test suite.
#
#   ./ledger daily            # generate today's issue, then self-improve
#   ./ledger weekly
#   ./ledger monthly
#   ./ledger python3 tests.py # run anything; it still triggers self-improve
#   ./ledger                  # just kick off a self-improvement pass
#
# Set LEDGER_NO_IMPROVE=1 to skip the self-improvement step for one invocation.
set -euo pipefail
cd "$(dirname "$0")"

rc=0
if [ "$#" -gt 0 ]; then
  if [ "$1" = "daily" ] || [ "$1" = "weekly" ] || [ "$1" = "monthly" ] || [ "$1" = "build" ]; then
    python3 generate.py "$@" || rc=$?
  else
    "$@" || rc=$?            # run any other command verbatim
  fi
fi

# generate.py already launches the improver itself; for other commands (or a
# bare ./ledger) we launch it here. The improver's lock prevents duplicates.
if [ "${LEDGER_NO_IMPROVE:-0}" != "1" ]; then
  nohup python3 improve.py >> data/improve.run.log 2>&1 &
  echo "↻ self-improvement running in background (tail data/improvements.log)"
fi

exit "$rc"
